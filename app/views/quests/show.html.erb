<div class="show-container">
    <!-- COLONNE GAUCHE : CHAT -->
    <div class="show-left">

      <div class="chat-wrapper">

        <!-- MESSAGES -->
        <div class="chat-messages" id="chat-messages">

          <% @quest.chat.messages.each do |message| %>

            <% if message.role == "user" %>

              <div class="message-row user-message">

                <div class="message-content">

                  <div class="message-role user-role">
                    <%= @quest.user.name %>
                  </div>

                  <div class="message-bubble user-bubble">
                    <%= message.content %>
                  </div>

                </div>

                <%= image_tag "avatar_user.png", class: "chat-avatar" %>

              </div>

            <% else %>

              <div class="message-row ai-message">

                <%= image_tag "avatar_ia.png", class: "chat-avatar" %>

                <div class="message-content me-3">

                  <div class="message-role ai-role">
                    Chef du village
                  </div>

                  <div class="message-bubble ai-bubble">
                    <%= message.content %>
                  </div>
                </div>

                <% if message.card_id %>
                  <%= link_to card_path(message.card), data: { turbo_frame: "card_frame" } do %>
                    <%= image_tag "see_quest.png", style: "height:80px; width:80px;" %>
                  <% end %>
                <% end %>

              </div>

            <% end %>

          <% end %>

        </div>

        <!-- INPUT -->
        <div class="chat-input-area">

          <%= simple_form_for [@quest, @message], html: { class: "chat-form" } do |f| %>

            <div class="input-wrapper">

            <%= f.text_field :content,
              class: "chat-input-field",
              placeholder: "Formule ta requête..." %>

            <%= f.button :submit,
                  "Envoyer",
                  class: "chat-send-btn" %>

          </div>

          <% end %>

        </div>

      </div>

    </div>

    <!-- COLONNE DROITE : CARD -->
    <div class="show-right">

      <% if @card.nil? %>
        <%= image_tag "creation_encours.png",
          class: "creationencours img-fluid" %>
      <% else %>
        <%= turbo_frame_tag "card_frame" do %>
          <%= render "/cards/card", card: @card %>
          <%= link_to "Valider cette quête", activate_card_path(@card), data: { turbo_method: :patch }, class: "ui-btn secondary small" %>

        <% end %>
      <% end %>
    </div>


</div>
